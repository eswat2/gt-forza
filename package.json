{
  "name": "gt-forza",
  "version": "0.0.446",
  "description": "prototype - simple serverless GraphQL api with mock data...",
  "author": "eswat2",
  "repository": "eswat2/gt-forza",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "dependencies": {
    "got": "15.1.0",
    "graphql": "17.0.2",
    "graphql-http": "1.22.4"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "vc --prod",
    "release": "pnpm bump && pnpm test && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "build": "echo --skip",
    "dev": "env-cmd -x -- vc dev --listen 8182 --token \\$API_TOKEN",
    "cc": "prettier --check './**/*.js'",
    "spell": "cspell './**/*.js'",
    "test": "echo skipping...",
    "format": "prettier --write server.js cSpell.json",
    "open": "open https://gt-forza.vercel.app/graphql"
  },
  "devDependencies": {
    "bumpp": "11.1.0",
    "env-cmd": "11.0.0",
    "only-allow": "1.2.2",
    "prettier": "3.9.5",
    "vercel": "56.2.1",
    "yoctocolors": "2.1.2"
  }
}
