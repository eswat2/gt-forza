{
  "name": "gt-forza",
  "version": "0.0.395",
  "description": "prototype - simple serverless GraphQL api with mock data...",
  "author": "eswat2",
  "repository": "eswat2/gt-forza",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.1.0+sha512.0c44e842e5686b2c061a81adda8b2258bd8818e9704b2cf2c63d56b931a7b2e910092e085027003b96ca3911ab56a07f6df5abaed2be9925034cdd686a535b14",
  "dependencies": {
    "got": "15.0.5",
    "graphql": "16.14.0",
    "graphql-http": "1.22.4"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "vc --prod",
    "release": "pnpm bump && pnpm test && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "build": "echo --skip",
    "dev": "env-cmd -x -- vc dev --listen 8182 --token \\$API_TOKEN",
    "cc": "prettier --check './**/*.js'",
    "spell": "cspell './**/*.js'",
    "test": "echo skipping...",
    "format": "prettier --write server.js cSpell.json",
    "open": "open https://gt-forza.vercel.app/graphql"
  },
  "devDependencies": {
    "bumpp": "11.1.0",
    "env-cmd": "11.0.0",
    "only-allow": "1.2.2",
    "prettier": "3.8.3",
    "vercel": "53.3.2",
    "yoctocolors": "2.1.2"
  }
}
