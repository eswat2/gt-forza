{
  "name": "gt-forza",
  "version": "0.0.400",
  "description": "prototype - simple serverless GraphQL api with mock data...",
  "author": "eswat2",
  "repository": "eswat2/gt-forza",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "dependencies": {
    "got": "15.0.5",
    "graphql": "16.14.0",
    "graphql-http": "1.22.4"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "vc --prod",
    "release": "pnpm bump && pnpm test && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "build": "echo --skip",
    "dev": "env-cmd -x -- vc dev --listen 8182 --token \\$API_TOKEN",
    "cc": "prettier --check './**/*.js'",
    "spell": "cspell './**/*.js'",
    "test": "echo skipping...",
    "format": "prettier --write server.js cSpell.json",
    "open": "open https://gt-forza.vercel.app/graphql"
  },
  "devDependencies": {
    "bumpp": "11.1.0",
    "env-cmd": "11.0.0",
    "only-allow": "1.2.2",
    "prettier": "3.8.3",
    "vercel": "54.1.0",
    "yoctocolors": "2.1.2"
  }
}
